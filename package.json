{
  "name": "react-antd-log",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "lint-staged",
    "git:check": "git diff --check --cached",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,scss,md}\"",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "antd": "^6.2.1",
    "axios": "^1.13.2",
    "classnames": "^2.5.1",
    "csstype": "^3.2.3",
    "detect-csv": "^1.1.0",
    "docx-preview": "^0.3.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "element-china-area-data": "^6.1.0",
    "file-type": "^21.3.0",
    "idb-keyval": "^6.2.2",
    "is-svg": "^6.1.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.3",
    "jspdf-font": "^1.0.7",
    "jszip": "^3.10.1",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-base-table": "^1.13.5",
    "react-dom": "^19.2.0",
    "react-pdf": "^10.3.0",
    "react-router-dom": "^7.12.0",
    "react-use": "^17.6.0",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@unocss/preset-attributify": "^66.6.0",
    "@unocss/preset-icons": "^66.6.0",
    "@unocss/preset-uno": "^66.6.0",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "unocss": "^66.6.0",
    "vite": "^7.2.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --max-warnings=0"
    ],
    "*.{json,md,css,scss}": [
      "prettier --check"
    ]
  }
}
